#!/usr/bin/env bash
# Karma launcher — run, upgrade, manage
# Usage: karma [gui|cli|golearn|upgrade|pull|status|log|clean|help]

set -euo pipefail

# Resolve KARMA_DIR: script location > env var > default
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KARMA_DIR="${KARMA_DIR:-$SCRIPT_DIR}"

cd "$KARMA_DIR" 2>/dev/null || { echo "Karma not found at $KARMA_DIR"; exit 1; }

cmd="${1:-}"
shift 2>/dev/null || true

case "$cmd" in

  # ── Run modes ──────────────────────────────────────────────
  gui|web)
    exec python3 ui/web.py
    ;;

  tui)
    exec python3 ui/cockpit.py
    ;;

  cli)
    exec python3 -m agent.agent_loop
    ;;

  doctor)
    exec python3 -m agent.agent_loop --doctor
    ;;

  golearn)
    # karma golearn "topic" minutes [mode]
    topic="${1:-}"
    mins="${2:-5}"
    mode="${3:-auto}"
    if [ -z "$topic" ]; then
      echo "Usage: karma golearn \"topic\" [minutes] [mode]"
      echo "  mode: depth | breadth | auto (default)"
      echo "  Example: karma golearn \"python asyncio\" 5 depth"
      exit 1
    fi
    python3 -c "
from agent.bootstrap import build_agent
agent = build_agent()
agent.run('golearn \"$topic\" $mins $mode')
"
    ;;

  # ── Upgrade ────────────────────────────────────────────────
  upgrade|pull)
    echo "=== Karma Upgrade ==="

    # Method 1: git pull (if .git exists)
    if [ -d .git ]; then
      echo "[1/2] Pulling from GitHub..."
      git pull origin main 2>&1 || echo "  git pull failed"
    else
      echo "[1/2] No .git — skipping pull"
    fi

    # Compile check
    echo "[2/2] Verifying..."
    errors=0
    for f in agent/agent_loop.py core/planner.py core/symbolic.py core/events.py \
             core/responder.py tools/tool_builder.py \
             research/session.py research/crawler.py research/brancher.py \
             research/index.py research/timekeeper.py \
             storage/memory.py tools/tool_interface.py ml/ml.py \
             ui/cockpit.py ui/web.py; do
      if [ -f "$f" ]; then
        python3 -m py_compile "$f" 2>/dev/null || { echo "  FAIL: $f"; errors=$((errors+1)); }
      fi
    done

    if [ "$errors" -eq 0 ]; then
      echo "=== Upgrade complete (all files OK) ==="
    else
      echo "=== Upgrade done with $errors compile errors ==="
    fi
    ;;

  # ── Status ─────────────────────────────────────────────────
  status)
    echo "=== Karma Status ==="
    echo "Dir: $KARMA_DIR"
    python3 -c "
import json, os
from pathlib import Path

# Config
with open('config.json') as f:
    cfg = json.load(f)
print(f'Version: {cfg[\"system\"][\"version\"]}')
print(f'Tools: {cfg[\"tools\"][\"enabled\"]}')

# Memory stats
facts_f = Path('data/facts.json')
if facts_f.exists():
    with open(facts_f) as f:
        facts = json.load(f)
    learn_facts = sum(1 for k in facts if k.startswith('learn:'))
    print(f'Facts: {len(facts)} total, {learn_facts} from golearn')

# Sessions
learn_dir = Path('data/learn')
if learn_dir.exists():
    sessions = [d for d in learn_dir.iterdir() if d.is_dir()]
    print(f'GoLearn sessions: {len(sessions)}')

# Events
ev = Path('data/events.jsonl')
if ev.exists():
    lines = ev.read_text().splitlines()
    print(f'Events logged: {len(lines)}')

# State
state_f = Path('data/agent_state.json')
if state_f.exists():
    with open(state_f) as f:
        st = json.load(f)
    print(f'Last run: {st.get(\"last_run\", \"never\")}')
    logs = st.get('execution_log', [])
    if logs:
        succ = sum(1 for l in logs if l.get('success'))
        print(f'Decisions: {len(logs)} ({succ} successful)')

# Disk
total = sum(f.stat().st_size for f in Path('.').rglob('*') if f.is_file() and '.git' not in str(f) and '.venv' not in str(f))
print(f'Disk: {total // 1024} KB')
" 2>/dev/null || echo "Could not read status"
    ;;

  # ── Log ────────────────────────────────────────────────────
  log)
    n="${1:-20}"
    if [ -f data/events.jsonl ]; then
      echo "=== Last $n events ==="
      tail -n "$n" data/events.jsonl | python3 -c "
import sys, json
for line in sys.stdin:
    try:
        e = json.loads(line)
        kind = e.get('kind','?')
        data = e.get('data',{})
        ts = e.get('t','')[-8:]
        detail = data.get('subtopic') or data.get('topic') or data.get('url','') or ''
        print(f'  {ts} {kind:20s} {str(detail)[:50]}')
    except: pass
"
    else
      echo "No events yet"
    fi
    ;;

  # ── Clean ──────────────────────────────────────────────────
  clean)
    echo "=== Karma Cleanup ==="
    # Remove __pycache__
    find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null
    echo "Cleared __pycache__"

    # Show learn sessions
    if [ -d data/learn ]; then
      count=$(find data/learn -maxdepth 1 -type d | wc -l)
      size=$(du -sh data/learn 2>/dev/null | cut -f1)
      echo "GoLearn data: $((count-1)) sessions, $size"
      read -p "Delete all learn sessions? [y/N] " ans
      if [ "$ans" = "y" ] || [ "$ans" = "Y" ]; then
        rm -rf data/learn/*
        echo "Cleared"
      fi
    fi

    # Show log size
    if [ -f data/logs/karma.log ]; then
      size=$(du -sh data/logs/karma.log | cut -f1)
      echo "Log file: $size"
      read -p "Truncate log? [y/N] " ans
      if [ "$ans" = "y" ] || [ "$ans" = "Y" ]; then
        > data/logs/karma.log
        echo "Truncated"
      fi
    fi

    # Events
    if [ -f data/events.jsonl ]; then
      lines=$(wc -l < data/events.jsonl)
      echo "Events: $lines entries"
      if [ "$lines" -gt 500 ]; then
        read -p "Trim to last 200? [y/N] " ans
        if [ "$ans" = "y" ] || [ "$ans" = "Y" ]; then
          tail -200 data/events.jsonl > data/events.jsonl.tmp
          mv data/events.jsonl.tmp data/events.jsonl
          echo "Trimmed"
        fi
      fi
    fi
    ;;

  # ── Next ───────────────────────────────────────────────────
  next)
    # Usage: karma next list
    sub="${1:-list}"
    shift 2>/dev/null || true
    if [ "$sub" = "list" ]; then
      python3 - <<'PY'
from storage.memory import MemorySystem
from pathlib import Path

mem = MemorySystem()
mem.load_all()

# Pending tasks (if tasks file uses id/title)
tasks = getattr(mem, 'tasks', {})
print('Pending tasks:')
if tasks:
    for tid, t in list(tasks.items())[:10]:
        title = t.get('title') or t.get('task') or ''
        status = t.get('status') or ''
        print(f'  - {tid}: {title} [{status}]')
else:
    print('  (no pending tasks)')

# Recent run history
runs = []
for k,v in mem.facts.items():
    if isinstance(v, dict) and v.get('topic') == 'run_history':
        runs.append((v.get('last_updated',''), k, v.get('value', v)))
runs.sort(reverse=True)
print('\nRecent runs:')
if runs:
    for ts,k,val in runs[:5]:
        summary = val.get('summary') if isinstance(val, dict) else str(val)
        print(f'  - {k} ({ts}): {summary}')
else:
    print('  (no recent runs)')
PY
    else
      echo "Unknown subcommand for next: $sub"
      exit 1
    fi
    ;;

  # ── Help ───────────────────────────────────────────────────
  help|--help|-h|"")
    cat <<'HELP'
Karma — Local Autonomous Agent

  karma gui                         Launch Web UI (Flask, port 5000)
  karma tui                         Launch Cockpit TUI (terminal)
  karma web                         Same as gui
  karma cli                         Launch CLI REPL
  karma golearn "topic" [min] [mode] Run golearn (default 5min, auto mode)

  karma upgrade                     Pull from GitHub + sync from Dell
  karma pull                        Same as upgrade
  karma status                      Show agent stats, facts, sessions
  karma log [n]                     Show last n events (default 20)
  karma clean                       Cleanup caches, old sessions, logs

  karma help                        This message
HELP
    ;;

  *)
    echo "Unknown command: $cmd"
    echo "Run 'karma help' for usage"
    exit 1
    ;;
esac
