{
  "system": {
    "name": "Karma",
    "version": "3.8.6",
    "offline": true,
    "deterministic": true
  },
  "memory": {
    "episodic_file": "data/episodic.jsonl",
    "facts_file": "data/facts.json",
    "tasks_file": "data/tasks.json",
    "state_file": "data/agent_state.json"
  },
  "tools": {
    "enabled": [
      "shell",
      "file",
      "system",
      "research"
    ],
    "research": {
      "max_session_minutes": 30,
      "max_page_size_kb": 500,
      "max_pages_per_slice": 3,
      "fetch_timeout": 15
    },
    "shell": {
      "timeout": 30,
      "allowed_commands": [
        "ls",
        "cat",
        "grep",
        "find",
        "pwd",
        "echo",
        "mkdir",
        "rm",
        "cp",
        "mv"
      ]
    },
    "file": {
      "max_size": 10485760,
      "allowed_paths": [
        "~",
        "/tmp",
        "/home",
        "/opt",
        "."
      ]
    }
  },
  "ml": {
    "models": {
      "intent_classifier": {
        "type": "naive_bayes",
        "train_file": "data/ml_intent_training.jsonl"
      },
      "candidate_scorer": {
        "type": "logistic_regression",
        "train_file": "data/ml_scoring_training.jsonl"
      }
    }
  },
  "logging": {
    "trace_file": "data/decision_trace.jsonl",
    "level": "DEBUG",
    "max_trace_size": 1000000,
    "log_dir": "data/logs"
  },
  "agent": {
    "active": true,
    "max_cycles": 1000,
    "recovery_enabled": true,
    "interrupt_safe": true
  },
  "web": {
    "host": "0.0.0.0",
    "port": 5000,
    "debug": false
  },
  "observer": {
    "enabled": true,
    "interval": 30,
    "watch_dirs": ["data", "tools"]
  },
  "confidence": {
    "threshold": 0.4,
    "low_action": "clarify"
  },
  "meta": {
    "cycle_interval": 20
  },
  "health": {
    "check_interval_cycles": 200,
    "auto_crystallize_cycles": 150
  },
  "governor": {
    "parse_cache_size": 96,
    "cooldown_failures": 3,
    "cooldown_turns": 3
  }
}